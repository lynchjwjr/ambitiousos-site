---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AccessRequestForm from '../components/AccessRequestForm.astro';
import '../styles/global.css';

const faqs = [
  {
    q: 'What is AmbitiousOS?',
    a: 'AmbitiousOS is your personal Chief AI Officer. It combines 2 years of curated AI research (thousands of pieces of content), an interactive knowledge graph, and an AI chat assistant trained on the full Reading Ambitiously archive — all in one platform.',
  },
  {
    q: 'How is AmbitiousOS different from ChatGPT or other AI tools?',
    a: 'AmbitiousOS is not a general-purpose chatbot. It is specifically trained on curated, high-quality research about AI, technology, and strategy from the Reading Ambitiously newsletter. Every answer comes from vetted, contextualized content — not the open internet.',
  },
  {
    q: 'What is Reading Ambitiously?',
    a: 'Reading Ambitiously is a free weekly newsletter delivered every Friday. Each edition covers the biggest ideas in AI and technology through curated research, charts, tweets, podcasts, and quotes. Every edition is fed back into AmbitiousOS to make the platform smarter.',
  },
  {
    q: 'How much does AmbitiousOS cost?',
    a: 'AmbitiousOS is currently in private beta. The Reading Ambitiously newsletter is free forever. Paid pricing for AmbitiousOS will be announced when the beta concludes.',
  },
  {
    q: 'How do I get access to AmbitiousOS?',
    a: 'Visit os.readingambitiously.com and request access. We are onboarding beta testers on a rolling basis.',
  },
  {
    q: 'What is the knowledge graph (Galaxy)?',
    a: 'The Galaxy is an interactive visualization that maps the connections between companies, people, concepts, and ideas across every edition of Reading Ambitiously. You can explore it to discover relationships and dive deeper into any topic.',
  },
  {
    q: 'Can I use AmbitiousOS on my phone?',
    a: 'Yes. AmbitiousOS is a progressive web app that works on any device — web, mobile, and desktop. Add it to your home screen for the best experience.',
  },
  {
    q: 'How often is new content added?',
    a: 'Every Friday. Each new edition of Reading Ambitiously is ingested into the platform, so AmbitiousOS gets smarter every single week.',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://ambitiousos.com' },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: 'https://ambitiousos.com/faq' },
  ],
};

const jsonLd = { '@context': 'https://schema.org', '@graph': [faqLd, breadcrumbLd] };
---

<Base
  title="FAQ — AmbitiousOS"
  description="Frequently asked questions about AmbitiousOS, your personal Chief AI Officer, and the Reading Ambitiously newsletter."
  jsonLd={jsonLd}
>
  <Header />
  <main class="section-padding">
    <div class="max-w-3xl mx-auto">
      <nav class="text-text-muted text-sm mb-8">
        <a href="/" class="hover:text-text-primary transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-text-secondary">FAQ</span>
      </nav>

      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">
        Frequently asked questions
      </h1>
      <p class="text-text-secondary text-lg mb-12 leading-relaxed">
        Everything you need to know about AmbitiousOS and Reading Ambitiously.
      </p>

      <div class="space-y-6">
        {faqs.map((faq) => (
          <details class="glass-card group">
            <summary class="cursor-pointer p-5 sm:p-6 flex items-start justify-between gap-4 list-none">
              <h2 class="text-text-primary font-medium text-base sm:text-lg">{faq.q}</h2>
              <span class="text-text-muted flex-shrink-0 transition-transform group-open:rotate-45 text-xl leading-none mt-0.5">+</span>
            </summary>
            <div class="px-5 sm:px-6 pb-5 sm:pb-6 -mt-2">
              <p class="text-text-secondary text-sm sm:text-base leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>

      <div class="mt-12 glass-card p-6 sm:p-8 text-center">
        <p class="text-text-primary font-medium mb-1">Ready to try it?</p>
        <p class="text-text-muted text-sm mb-4">Request access to AmbitiousOS — your personal Chief AI Officer.</p>
        <AccessRequestForm id="faq-access" inline />
      </div>
    </div>
  </main>
  <Footer />
</Base>
