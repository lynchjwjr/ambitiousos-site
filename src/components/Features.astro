---
import AccessRequestForm from './AccessRequestForm.astro';

const features = [
  {
    icon: '📚',
    title: '5,000+ pieces of curated content',
    description: '2 years of research distilled into one searchable, AI-powered knowledge base.',
  },
  {
    icon: '🌌',
    title: 'Interactive knowledge graph',
    description: 'A galaxy visualization connecting companies, people, concepts, and ideas across every edition.',
  },
  {
    icon: '🤖',
    title: 'AI chat on the full archive',
    description: 'Ask anything. Your Chief AI Officer is trained on 64+ editions of Reading Ambitiously.',
  },
  {
    icon: '🗓️',
    title: 'New content every Friday',
    description: 'Every edition feeds back into the system. AmbitiousOS gets smarter every single week.',
  },
];

const examplePrompts = [
  'What are the biggest ideas from the last 5 editions?',
  'Explain context engineering like I\'m new to AI',
  'How is AI reshaping enterprise SaaS moats and pricing?',
  'Compare the Anthropic vs OpenAI coverage across editions',
  'What does Jack mean by high-agency teams?',
  'What patterns connect AI, Jevons Paradox, and enterprise adoption?',
];
---

<section class="section-padding" id="features">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-text-primary text-center mb-4">
      What is AmbitiousOS?
    </h2>
    <p class="text-text-secondary text-center max-w-2xl mx-auto mb-12 text-lg leading-relaxed">
      A vast amount of intelligence about AI and the most powerful ideas shaping the world &mdash;
      all in one place, getting smarter every week.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-14">
      {features.map((f) => (
        <div class="glass-card p-6">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">{f.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>

    <!-- Example prompts -->
    <div class="max-w-2xl mx-auto">
      <p class="text-text-muted text-sm text-center mb-4 uppercase tracking-wider font-medium">
        Try asking your Chief AI Officer
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {examplePrompts.map((prompt) => (
          <span class="prompt-chip">&ldquo;{prompt}&rdquo;</span>
        ))}
      </div>
    </div>

    <div class="text-center mt-10">
      <button type="button" class="btn-primary" data-open-form="features-access-form" onclick="if(typeof plausible==='function')plausible('CTA Click',{props:{location:'features',type:'request-access'}})">
        Request Access
        <span aria-hidden="true">&rarr;</span>
      </button>
    </div>

    <div class="max-w-lg mx-auto mt-4">
      <AccessRequestForm id="features-access-form" />
    </div>
  </div>
</section>

<style>
  .prompt-chip {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(30, 28, 23, 0.8);
    border: 1px solid rgba(238, 228, 219, 0.08);
    border-radius: 9999px;
    font-size: 0.8125rem;
    color: #aaa;
    white-space: nowrap;
  }
</style>
