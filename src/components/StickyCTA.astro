---
import AccessRequestForm from './AccessRequestForm.astro';
/* Mobile sticky CTA — shows after scrolling past hero, hides when hero is visible */
---

<div class="sticky-cta" id="sticky-cta" aria-hidden="true">
  <button type="button" class="sticky-cta-btn" data-open-form="sticky-access-form" onclick="if(typeof plausible==='function')plausible('CTA Click',{props:{location:'sticky',type:'request-access'}})">
    Request Access <span aria-hidden="true">&rarr;</span>
  </button>
  <div class="sticky-form-wrap" id="sticky-form-container">
    <AccessRequestForm id="sticky-access-form" />
  </div>
</div>

<style>
  .sticky-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 0.75rem 1rem;
    padding-bottom: max(0.75rem, env(safe-area-inset-bottom));
    background: rgba(12, 11, 9, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid rgba(238, 228, 219, 0.06);
    transform: translateY(100%);
    transition: transform 0.3s ease;
    pointer-events: none;
  }

  .sticky-cta.is-visible {
    transform: translateY(0);
    pointer-events: auto;
  }

  .sticky-cta-btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.875rem;
    background: #024536;
    color: #eee4db;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: background 0.2s ease;
    border: none;
    cursor: pointer;
  }

  .sticky-cta-btn:hover {
    background: #036B4E;
  }

  .sticky-form-wrap {
    margin-top: 0.5rem;
  }

  /* Only show on mobile/tablet */
  @media (min-width: 1024px) {
    .sticky-cta {
      display: none;
    }
  }
</style>

<script>
  const stickyCta = document.getElementById('sticky-cta');
  const hero = document.getElementById('hero');

  if (stickyCta && hero) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            stickyCta.classList.remove('is-visible');
            stickyCta.setAttribute('aria-hidden', 'true');
          } else {
            stickyCta.classList.add('is-visible');
            stickyCta.setAttribute('aria-hidden', 'false');
          }
        }
      },
      { threshold: 0 }
    );
    observer.observe(hero);
  }
</script>
